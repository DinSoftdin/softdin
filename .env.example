# URL pública de la API Laravel (APP_URL en softdin-api + /api/v1).
# Debe apuntar al servidor donde corre la API, NO al frontend.
#
# Ejemplos:
#   Local API en puerto 8080:  VITE_API_URL=http://localhost:8080/api/v1
#   Local API en puerto 8000:  VITE_API_URL=http://localhost:8000/api/v1
#   Dokploy / producción:      VITE_API_URL=https://api.tudominio.com/api/v1
#
# Tras cambiar este valor, reinicie: npm run dev
VITE_API_URL=http://localhost:8080/api/v1
